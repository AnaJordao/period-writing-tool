generator client {
  provider     = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  header      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}
